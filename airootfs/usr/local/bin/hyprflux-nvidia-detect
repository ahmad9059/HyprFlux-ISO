#!/bin/bash
# hyprflux-nvidia-detect — NVIDIA GPU auto-detection for HyprFlux live ISO
#
# This script is run at boot to detect NVIDIA GPUs and configure the environment.
# It can be invoked by:
#   1. The systemd service (hyprflux-nvidia-detect.service)
#   2. Manually by the user
#
# When an NVIDIA GPU is detected, it:
#   - Loads the nvidia kernel modules
#   - Creates environment variable configs for Hyprland
#   - Enables GBM backend
set -euo pipefail

NVIDIA_ENV_FILE="/etc/environment.d/nvidia.conf"
HYPR_NVIDIA_CONF="/etc/skel/.config/hypr/configs/NvidiaEnv.conf"
LOG_TAG="hyprflux-nvidia"

log() {
    echo "[${LOG_TAG}] $*"
    logger -t "${LOG_TAG}" "$*" 2>/dev/null || true
}

detect_nvidia() {
    # Check for NVIDIA GPU via lspci
    if lspci -d '10de:' 2>/dev/null | grep -qi 'vga\|3d\|display'; then
        return 0
    fi
    return 1
}

check_nvidia_cmdline() {
    # Check if nvidia-drm.modeset=1 was passed on kernel command line
    if grep -q 'nvidia-drm.modeset=1' /proc/cmdline 2>/dev/null; then
        return 0
    fi
    return 1
}

check_nomodeset() {
    # Check if nomodeset was passed (safe graphics mode)
    if grep -q 'nomodeset' /proc/cmdline 2>/dev/null; then
        return 0
    fi
    return 1
}

configure_nvidia() {
    log "NVIDIA GPU detected. Configuring environment..."

    # Load NVIDIA kernel modules
    modprobe nvidia 2>/dev/null || log "Warning: nvidia module not loaded"
    modprobe nvidia_modeset 2>/dev/null || log "Warning: nvidia_modeset not loaded"
    modprobe nvidia_uvm 2>/dev/null || log "Warning: nvidia_uvm not loaded"
    modprobe nvidia_drm modeset=1 2>/dev/null || log "Warning: nvidia_drm not loaded"

    # Set environment variables for all users
    mkdir -p "$(dirname "${NVIDIA_ENV_FILE}")"
    cat > "${NVIDIA_ENV_FILE}" <<'EOF'
# NVIDIA environment variables (auto-generated by hyprflux-nvidia-detect)
GBM_BACKEND=nvidia-drm
__GLX_VENDOR_LIBRARY_NAME=nvidia
LIBVA_DRIVER_NAME=nvidia
__GL_GSYNC_ALLOWED=1
__GL_VRR_ALLOWED=1
NVD_BACKEND=direct
ELECTRON_OZONE_PLATFORM_HINT=auto
EOF

    # Create Hyprland env config for NVIDIA
    local hypr_nvidia_dir
    hypr_nvidia_dir="$(dirname "${HYPR_NVIDIA_CONF}")"
    mkdir -p "${hypr_nvidia_dir}"
    cat > "${HYPR_NVIDIA_CONF}" <<'EOF'
# NVIDIA environment for Hyprland (auto-generated by hyprflux-nvidia-detect)
env = GBM_BACKEND,nvidia-drm
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = LIBVA_DRIVER_NAME,nvidia
env = __GL_GSYNC_ALLOWED,1
env = __GL_VRR_ALLOWED,1
env = NVD_BACKEND,direct
env = ELECTRON_OZONE_PLATFORM_HINT,auto

cursor {
    no_hardware_cursors = true
}
EOF

    # Also write to the live user's config if they already exist
    local live_user_conf="/home/hyprflux/.config/hypr/configs/NvidiaEnv.conf"
    if [[ -d "/home/hyprflux/.config/hypr/configs" ]]; then
        cp "${HYPR_NVIDIA_CONF}" "${live_user_conf}"
        chown 1000:1000 "${live_user_conf}" 2>/dev/null || true
    fi

    log "NVIDIA configuration applied."
}

main() {
    # If nomodeset is set, skip NVIDIA entirely (safe graphics mode)
    if check_nomodeset; then
        log "nomodeset detected. Skipping NVIDIA configuration."
        exit 0
    fi

    # If nvidia-drm.modeset=1 is on the command line, force NVIDIA config
    if check_nvidia_cmdline; then
        log "nvidia-drm.modeset=1 found on kernel command line."
        configure_nvidia
        exit 0
    fi

    # Auto-detect: check if NVIDIA GPU is present
    if detect_nvidia; then
        configure_nvidia
    else
        log "No NVIDIA GPU detected. Using default (Mesa) drivers."
    fi
}

main "$@"
